{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/melville/taxonomy.schema.json",
  "title": "Moby-Dick Taxonomy",
  "type": "object",
  "required": ["trails", "entities"],
  "additionalProperties": false,
  "properties": {
    "trails": {
      "type": "array",
      "items": { "$ref": "#/$defs/trail" },
      "uniqueItems": true
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/$defs/entity" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "trail": {
      "type": "object",
      "required": ["id", "label", "description", "tags", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9:-]*$" },
          "uniqueItems": true
        },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "entity": {
      "type": "object",
      "required": ["id", "label", "kind", "aliases", "citations", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "label": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["character", "place", "ship", "animal", "symbol", "theme", "form", "concept", "allusion", "topic"]
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "citations": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "status": { "$ref": "#/$defs/status" }
      }
    },
    "status": {
      "type": "object",
      "required": ["content_status", "citation_status"],
      "additionalProperties": false,
      "properties": {
        "content_status": { "enum": ["student-ready", "draft", "needs-review"] },
        "citation_status": { "enum": ["verified", "provisional", "needs-review"] }
      }
    }
  }
}
