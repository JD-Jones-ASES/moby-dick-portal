{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/melville/annotation-layer.schema.json",
  "title": "Annotation Layer Registry",
  "type": "object",
  "required": ["depths", "kind_defaults", "density_thresholds"],
  "additionalProperties": false,
  "properties": {
    "depths": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/depth" },
      "uniqueItems": true
    },
    "kind_defaults": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/displayRule" }
    },
    "density_thresholds": {
      "type": "object",
      "required": ["guide_inline_marks_per_unit", "study_inline_marks_per_paragraph", "study_inline_marks_per_unit"],
      "additionalProperties": false,
      "properties": {
        "guide_inline_marks_per_unit": { "type": "integer", "minimum": 0 },
        "study_inline_marks_per_paragraph": { "type": "integer", "minimum": 1 },
        "study_inline_marks_per_unit": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "depth": {
      "type": "object",
      "required": ["id", "title", "inline_annotations", "apparatus", "student_visible"],
      "additionalProperties": false,
      "properties": {
        "id": { "enum": ["read", "guide", "study", "explore", "teacher"] },
        "title": { "type": "string", "minLength": 1 },
        "inline_annotations": { "type": "boolean" },
        "apparatus": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        },
        "student_visible": { "type": "boolean" }
      }
    },
    "displayRule": {
      "type": "object",
      "required": ["depth", "priority", "inline", "surfaces", "spoiler_level"],
      "additionalProperties": false,
      "properties": {
        "depth": { "enum": ["read", "guide", "study", "explore", "teacher"] },
        "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
        "inline": { "type": "boolean" },
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["reader", "margin-card", "trail", "index", "search", "map", "review", "teacher"]
          },
          "uniqueItems": true
        },
        "spoiler_level": { "enum": ["none", "mild", "major", "teacher-only"] }
      }
    }
  }
}
