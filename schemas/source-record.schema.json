{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/melville/source-record.schema.json",
  "title": "Source Record Collection",
  "type": "object",
  "required": ["records"],
  "additionalProperties": false,
  "properties": {
    "records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceRecord" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "sourceRecord": {
      "type": "object",
      "required": ["id", "kind", "title", "author", "publisher", "url", "local_path", "source_note", "license_note", "citation_status"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "kind": {
          "enum": [
            "source-text",
            "dictionary",
            "encyclopedia",
            "biblical-text",
            "classical-text",
            "historical-primary",
            "historical-secondary",
            "scholarly",
            "map",
            "image",
            "license",
            "other"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "bibliographic_note": { "type": "string" },
        "accessed": {
          "anyOf": [
            { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            { "type": "null" }
          ]
        },
        "local_path": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "source_note": { "type": "string", "minLength": 1 },
        "license_note": { "type": "string", "minLength": 1 },
        "citation_status": {
          "enum": ["verified-from-vendored-opf", "verified", "provisional", "needs-review"]
        }
      }
    }
  }
}
