{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/melville/teacher-packet.schema.json",
  "title": "Teacher Packet Collection",
  "type": "object",
  "required": ["packets"],
  "additionalProperties": false,
  "properties": {
    "packets": {
      "type": "array",
      "items": { "$ref": "#/$defs/teacherPacket" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "teacherPacket": {
      "type": "object",
      "required": [
        "id",
        "unit_id",
        "essential_question",
        "discussion_prompts",
        "likely_misreadings",
        "difficult_material_handles",
        "linked_trails",
        "linked_reference_cards",
        "linked_annotations",
        "teacher_takeaway",
        "provenance",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "unit_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "essential_question": { "type": "string", "minLength": 1 },
        "discussion_prompts": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/discussionPrompt" }
        },
        "likely_misreadings": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "difficult_material_handles": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        },
        "linked_trails": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        },
        "linked_reference_cards": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        },
        "linked_annotations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        },
        "teacher_takeaway": { "type": "string", "minLength": 1 },
        "provenance": {
          "type": "object",
          "required": ["author", "created", "method"],
          "additionalProperties": false,
          "properties": {
            "author": { "type": "string", "minLength": 1 },
            "created": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "method": { "enum": ["hand-authored", "source-checked-draft", "subagent-draft", "generated", "reviewed"] }
          }
        },
        "status": {
          "type": "object",
          "required": ["content_status", "citation_status", "review_queue"],
          "additionalProperties": false,
          "properties": {
            "content_status": { "enum": ["student-ready", "draft", "needs-review"] },
            "citation_status": { "enum": ["verified", "provisional", "needs-review"] },
            "review_queue": {
              "type": "array",
              "items": {
                "enum": ["teacher", "source-check", "citation", "tone", "difficult-material", "interpretive"]
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "discussionPrompt": {
      "type": "object",
      "required": ["id", "prompt", "linked_annotations", "linked_reference_cards", "linked_trails"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "prompt": { "type": "string", "minLength": 1 },
        "linked_annotations": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        },
        "linked_reference_cards": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        },
        "linked_trails": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "uniqueItems": true
        }
      }
    }
  }
}
