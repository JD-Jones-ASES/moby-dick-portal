---
import Layout from "../../components/Layout.astro";
import { loadGuideData } from "../../lib/guide-data.js";

const data = await loadGuideData();
const entries = [...data.glossary].sort((a, b) => a.term.localeCompare(b.term, "en", { sensitivity: "base" }));
const categories = [...new Set(entries.map((e) => e.category))].sort();
---

<Layout title="Glossary" current="glossary" description="Defined and cited nautical, whaling, biblical, and classical terms from Moby-Dick.">
  <div class="wrap">
    <div class="page-head">
      <p class="eyebrow">Look up</p>
      <h1>Glossary</h1>
      <p class="lede">{entries.length} student-ready terms — each defined plainly and grounded in a cited source.</p>
    </div>

    <div class="toc-controls">
      <input id="g-search" type="search" placeholder="Search terms and definitions…" aria-label="Search glossary" />
      <select id="g-cat" aria-label="Filter by category">
        <option value="">All categories</option>
        {categories.map((c) => <option value={c}>{c[0].toUpperCase() + c.slice(1)}</option>)}
      </select>
    </div>

    <dl class="gloss-grid" id="g-list">
      {entries.map((e) => (
        <div class="gloss" id={`g-${e.id}`} data-g data-text={`${e.term} ${e.definition} ${(e.variants ?? []).join(" ")}`.toLowerCase()} data-cat={e.category}>
          <dt>{e.term} <span class="cat">{e.category}</span></dt>
          <dd>{e.definition}{e.variants?.length ? <span class="muted"> · also: {e.variants.join(", ")}</span> : null}</dd>
        </div>
      ))}
    </dl>
    <p id="g-empty" class="muted hide" style="padding:2rem 0;">No terms match.</p>
  </div>

  <script is:inline>
    (function () {
      const q = document.getElementById("g-search");
      const cat = document.getElementById("g-cat");
      const items = Array.from(document.querySelectorAll("[data-g]"));
      const empty = document.getElementById("g-empty");
      function apply() {
        const t = q.value.trim().toLowerCase();
        const c = cat.value;
        let shown = 0;
        items.forEach((el) => {
          const show = (!t || el.dataset.text.includes(t)) && (!c || el.dataset.cat === c);
          el.classList.toggle("hide", !show);
          if (show) shown++;
        });
        empty.classList.toggle("hide", shown !== 0);
      }
      [q, cat].forEach((el) => el.addEventListener("input", apply));
    })();
  </script>
</Layout>
