---
import Layout from "../components/Layout.astro";
import { loadGuideData } from "../lib/guide-data.js";
import { withBase, unitHref, sourceMap, pathMeta } from "../lib/site.js";

const data = await loadGuideData();
const chapters = data.units.filter((u) => u.section_type === "chapter");
const verifiedSources = [...sourceMap.values()].filter((s) => s.citation_status === "verified" && s.id !== "standard-ebooks-moby-dick");
const externalTeaching = data.annotations.filter((a) =>
  (a.evidence ?? []).some((e) => e.claim_type !== "source-text-observation" && e.claim_type !== "interpretive")
).length;

const stats = [
  { n: chapters.length, l: "Chapters" },
  { n: data.annotations.length, l: "Study notes" },
  { n: externalTeaching, l: "Teach outside knowledge" },
  { n: verifiedSources.length, l: "Cited sources" }
];

const tiles = [
  { href: withBase("chapters/"), kicker: "Read", title: "All chapters", body: "Every reading unit with summaries, path badges, and study-note counts." },
  { href: withBase("paths/"), kicker: "Choose", title: "Reading paths", body: "Narrative Core, Classroom Standard, or the Full Text — one source, your length." },
  { href: withBase("glossary/"), kicker: "Look up", title: "Glossary", body: "Nautical, whaling, biblical, and classical terms, each defined and cited." },
  { href: withBase("sources/"), kicker: "Verify", title: "Sources", body: "The bibliography every study note is grounded in." },
  { href: withBase("map/"), kicker: "Trace", title: "Voyage map", body: "The Pequod's stages as a guide — display anchors, not a charted route." },
  { href: withBase("about/"), kicker: "Why", title: "About the edition", body: "How the paths work and how every study note is held to a cited standard." }
];
---

<Layout current="">
  <section class="wrap hero">
    <p class="page-head eyebrow" style="padding:0;">A guided student edition</p>
    <h1>Moby-Dick;<br />or, The Whale</h1>
    <p class="lede">
      Read the short narrative path, a classroom path, a thematic route, or Melville's full novel —
      all from one source. Every difficult allusion, whaling term, and biblical echo is explained
      where it appears, with a real citation behind it.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href={unitHref("chapter-001-loomings")}>Start reading →</a>
      <a class="btn btn-ghost" href={withBase("chapters/")}>Browse all chapters</a>
    </div>
  </section>

  <div class="wrap">
    <div class="stats">
      {stats.map((s) => (
        <div class="stat"><div class="n">{s.n.toLocaleString()}</div><div class="l">{s.l}</div></div>
      ))}
    </div>

    <h2 class="section-h">Choose how much to carry</h2>
    <div class="grid cols-3">
      {Object.entries(pathMeta).map(([id, m]) => (
        <a class="card" href={withBase("paths/") + `#${id}`}>
          <span class="kicker">Path</span>
          <h3>{m.label}</h3>
          <p>{m.blurb}</p>
        </a>
      ))}
    </div>

    <h2 class="section-h">Explore the edition</h2>
    <div class="grid cols-3">
      {tiles.map((t) => (
        <a class="card" href={t.href}>
          <span class="kicker">{t.kicker}</span>
          <h3>{t.title}</h3>
          <p>{t.body}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
