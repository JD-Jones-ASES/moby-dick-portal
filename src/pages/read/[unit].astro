---
import Layout from "../../components/Layout.astro";
import { loadGuideData } from "../../lib/guide-data.js";
import { renderUnit } from "../../lib/render.js";
import {
  unitHref, unitKicker, pathMeta, primaryClaim, claimInfo, externalCitations, sourceInfo, withBase
} from "../../lib/site.js";
import { lensesForUnit } from "../../lib/explore.js";
import ChapterFlourish from "../../components/ChapterFlourish.astro";
import AmbientSound from "../../components/AmbientSound.astro";
import bigRead from "../../../data/references/big-read-links.json";

// External Big Read audio link for this unit (chapter or epilogue), or null. Link out only.
function bigReadUrl(unit) {
  if (unit.section_type === "epilogue") return `${bigRead.base}/${bigRead.epilogue_slug}/`;
  if (unit.section_type === "chapter" && unit.number != null) {
    const slug = bigRead.slugs[String(unit.number)];
    if (slug) return `${bigRead.base}/chapter-${unit.number}-${slug}/`;
  }
  return null;
}

export async function getStaticPaths() {
  const data = await loadGuideData();
  const ordered = [...data.units].sort((a, b) => a.sequence - b.sequence);

  return ordered.map((unit, i) => {
    const annotations = data.annotationIndex.units[unit.unit_id]?.annotations ?? [];

    // One glossary array, used for BOTH the inline marks and the sidebar cards, so every
    // marked term is guaranteed a card to link to (mark-set is a subset of card-set).
    const glossary = data.glossary
      .filter((g) => (g.targets ?? []).includes(unit.unit_id))
      .slice(0, 30);

    const { html, placed } = renderUnit(unit.plain_text, annotations, glossary);
    const byId = new Map(annotations.map((a) => [a.id, a]));
    const notes = placed.map((id) => byId.get(id)).filter(Boolean);
    const references = data.referenceCards.filter((c) => (c.targets ?? []).includes(unit.unit_id));

    const prev = i > 0 ? ordered[i - 1] : null;
    const next = i < ordered.length - 1 ? ordered[i + 1] : null;

    return {
      params: { unit: unit.unit_id },
      props: {
        unit, html, notes, glossary, references,
        lenses: lensesForUnit(unit.unit_id),
        prev: prev && { unit_id: prev.unit_id, title: prev.title, kicker: unitKicker(prev) },
        next: next && { unit_id: next.unit_id, title: next.title, kicker: unitKicker(next) }
      }
    };
  });
}

const { unit, html, notes, glossary, references, prev, next, lenses } = Astro.props;
const kicker = unitKicker(unit);
const bigReadLink = bigReadUrl(unit);
const paths = Object.entries(pathMeta)
  .map(([id, meta]) => ({ id, meta, status: unit.paths?.[id] }))
  .filter((p) => p.status && p.status !== "excluded");

function noteCitations(a) {
  return externalCitations(a).map((id) => {
    const s = sourceInfo(id);
    return { title: s.title, url: s.url };
  });
}
---

<Layout title={`${kicker}: ${unit.title}`} current="read" reader description={unit.summaries?.one_breath}>
  <div class="reading-progress" aria-hidden="true">
    <span class="bar" id="reading-progress-bar"></span>
  </div>
  <div class="wrap">
    <article class="reader" data-unit-id={unit.unit_id}>
      <div class="reader-main">
        {(unit.section_type === "chapter" || unit.section_type === "epilogue") && <ChapterFlourish />}
        <p class="reader-kicker">{kicker}</p>
        <h1 class="reader-title">{unit.title}</h1>
        <div class="path-badges">
          {paths.map((p) => (
            <span class={`badge ${p.status === "required" ? "req" : ""}`}>{p.meta.short}{p.status === "required" ? "" : " (optional)"}</span>
          ))}
          {unit.word_count ? <span class="badge">{unit.word_count.toLocaleString()} words</span> : null}
          {notes.length ? <span class="badge">{notes.length} study {notes.length === 1 ? "note" : "notes"}</span> : null}
        </div>

        {unit.summaries?.one_breath && (
          <div class="summary-card">
            <p class="one">{unit.summaries.one_breath}</p>
            {unit.summaries.why_it_matters && (
              <>
                <span class="lbl">Why it matters</span>
                <p class="why">{unit.summaries.why_it_matters}</p>
              </>
            )}
          </div>
        )}

        {glossary.length > 0 && (
          <div class="reader-tools">
            <span class="legend"><span class="swatch anno"></span> study note</span>
            <span class="legend"><span class="swatch gloss"></span> glossary term</span>
            <button class="tool-toggle" id="gloss-toggle" type="button" aria-pressed="true">Glossary marks: on</button>
          </div>
        )}

        <div class="prose" id="prose" set:html={html} />

        <nav class="pager">
          {prev ? (
            <a class="card" href={unitHref(prev.unit_id)}>
              <span class="dir">← Previous</span>
              <div class="t">{prev.kicker}: {prev.title}</div>
            </a>
          ) : <span />}
          {next ? (
            <a class="card next" href={unitHref(next.unit_id)}>
              <span class="dir">Next →</span>
              <div class="t">{next.kicker}: {next.title}</div>
            </a>
          ) : <span />}
        </nav>
      </div>

      <aside class="reader-side">
        {bigReadLink && (
          <div class="notes big-read">
            <h2>Listen</h2>
            <a class="big-read-link" href={bigReadLink} rel="noopener noreferrer" target="_blank">
              <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M4 8 L4 12 L7 12 L11 15 L11 5 L7 8 Z" stroke-linejoin="round"></path>
                <path d="M14 7 Q16 10 14 13" stroke-linecap="round"></path>
              </svg>
              <span>Hear this chapter read aloud</span>
              <span class="ext" aria-hidden="true">↗</span>
              <span class="sr-only">(opens the Moby-Dick Big Read in a new tab)</span>
            </a>
            <p class="big-read-note">A free recording from the <em>Moby-Dick Big Read</em> — a different voice for every chapter. Opens in a new tab.</p>
          </div>
        )}

        {(lenses.trails.length > 0 || lenses.entities.length > 0) && (
          <div class="notes appears-in">
            <h2>This chapter appears in</h2>
            <div class="chip-row">
              {lenses.trails.map((t) => (
                <a class="chip chip-trail" href={withBase(`trails/${t.id}/`)}>{t.label}</a>
              ))}
              {lenses.entities.map((e) => (
                <a class="chip chip-entity" href={withBase(`entity/${e.id}/`)}>{e.label}</a>
              ))}
            </div>
          </div>
        )}

        {notes.length > 0 && (
          <div class="notes">
            <h2>Study notes</h2>
            {notes.map((a) => {
              const claim = claimInfo(primaryClaim(a));
              const cites = noteCitations(a);
              return (
                <div class="note" id={`note-${a.id}`}>
                  <span class={`claim ${claim.cls}`}>{claim.label}</span>
                  <a class="anchor-q" href={`#mark-${a.id}`}>“{a.anchor}”</a>
                  <p class="body">{a.note}</p>
                  {cites.length > 0 && (
                    <p class="cite">Source: {cites.map((c, idx) => (
                      <>{idx > 0 ? ", " : ""}{c.url ? <a href={c.url} rel="noopener" target="_blank">{c.title}</a> : c.title}</>
                    ))}</p>
                  )}
                </div>
              );
            })}
          </div>
        )}

        {glossary.length > 0 && (
          <div class="notes">
            <h2>Glossary in this chapter</h2>
            <dl class="gloss-list">
              {glossary.map((g) => (
                <div class="gloss" id={`gcard-${g.id}`} data-gloss={g.id} tabindex="0">
                  <dt>{g.term} <span class="cat">{g.category}</span></dt>
                  <dd>{g.definition}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        {references.length > 0 && (
          <div class="notes">
            <h2>Reference cards</h2>
            {references.map((c) => (
              <div class="note"><span class="anchor-q">{c.title}</span><p class="body">{c.summary}</p></div>
            ))}
          </div>
        )}
      </aside>
    </article>
  </div>

  <div class="reader-dock" aria-label="Reading controls">
    <button type="button" class="dock-btn" id="focus-toggle" aria-pressed="false" title="Focus mode — hide the sidebar (Esc to exit)">
      <span class="dock-ico" aria-hidden="true">⤢</span><span class="dock-txt">Focus</span>
    </button>
    <AmbientSound />
    <details class="dock-panel" id="typo-details">
      <summary class="dock-btn" title="Reading typography" aria-label="Typography settings">Aa</summary>
      <div class="typo-panel" role="group" aria-label="Typography">
        <div class="typo-row">
          <span class="typo-label">Size</span>
          <div class="typo-ctl">
            <button type="button" data-typo="size-dec" aria-label="Smaller text">A−</button>
            <button type="button" data-typo="size-inc" aria-label="Larger text">A+</button>
          </div>
        </div>
        <div class="typo-row">
          <span class="typo-label">Spacing</span>
          <div class="typo-ctl">
            <button type="button" data-typo="lead-dec" aria-label="Tighter line spacing">−</button>
            <button type="button" data-typo="lead-inc" aria-label="Looser line spacing">+</button>
          </div>
        </div>
        <div class="typo-row">
          <span class="typo-label">Width</span>
          <div class="typo-seg">
            <button type="button" data-typo="measure" data-val="60ch" aria-pressed="false">Narrow</button>
            <button type="button" data-typo="measure" data-val="70ch" aria-pressed="true">Normal</button>
            <button type="button" data-typo="measure" data-val="84ch" aria-pressed="false">Wide</button>
          </div>
        </div>
        <div class="typo-row">
          <span class="typo-label">Type</span>
          <div class="typo-seg">
            <button type="button" data-typo="family" data-val="var(--serif)" aria-pressed="true">Serif</button>
            <button type="button" data-typo="family" data-val="var(--sans)" aria-pressed="false">Sans</button>
          </div>
        </div>
        <button type="button" class="typo-reset" data-typo="reset">Reset to default</button>
        <span class="sr-only" id="typo-status" aria-live="polite"></span>
      </div>
    </details>
  </div>

  <script>
    import { initReader } from "../../lib/reader-ui.js";
    initReader();
  </script>
</Layout>
