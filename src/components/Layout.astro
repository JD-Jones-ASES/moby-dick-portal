---
import "../styles/portal.css";
import coverImage from "../../vendor/standard-ebooks/herman-melville_moby-dick-master/images/cover.jpg";
import { withBase } from "../lib/site.js";
import SearchOverlay from "./SearchOverlay.astro";

const { title, description = "A guided student edition of Herman Melville's Moby-Dick — read it at the depth you choose.", current = "", reader = false } = Astro.props;
const fullTitle = title ? `${title} — Moby-Dick Portal` : "Moby-Dick — A Student Edition";

const nav = [
  { id: "read", label: "Read", href: withBase("chapters/") },
  { id: "paths", label: "Paths", href: withBase("paths/") },
  { id: "glossary", label: "Glossary", href: withBase("glossary/") },
  { id: "sources", label: "Sources", href: withBase("sources/") },
  { id: "map", label: "Map", href: withBase("map/") },
  { id: "explore", label: "Explore", href: withBase("explorer/") },
  { id: "about", label: "About", href: withBase("about/") }
];
---

<!DOCTYPE html>
<html lang="en" data-theme="paper">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={coverImage.src} />
    <script is:inline>
      // No-flash: apply stored reading preferences before first paint to avoid a layout jump.
      // Theme is global; focus mode and the --reader-* type vars are reader-page concerns, but
      // applying them here is harmless elsewhere (CSS scopes focus to body.reader-page, and the
      // --reader-* vars are only consumed by .prose).
      try {
        const t = localStorage.getItem("mdp-theme");
        if (t) document.documentElement.dataset.theme = t;
      } catch (e) {}
      try {
        const root = document.documentElement;
        if (localStorage.getItem("mdp-focus") === "on") root.dataset.focus = "on";
        const typo = JSON.parse(localStorage.getItem("mdp-typo") || "null");
        if (typo && typeof typo === "object") {
          if (typo.size) root.style.setProperty("--reader-size", typo.size);
          if (typo.leading) root.style.setProperty("--reader-leading", typo.leading);
          if (typo.measure) root.style.setProperty("--reader-measure", typo.measure);
          if (typo.family) root.style.setProperty("--reader-font", typo.family);
        }
      } catch (e) {}
    </script>
  </head>
  <body class={reader ? "reader-page" : undefined}>
    <header class="site-header">
      <div class="wrap nav">
        <a class="brand" href={withBase("")}>
          <img class="mark" src={coverImage.src} alt="" width="30" height="44" />
          <span class="full">Moby-Dick</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} aria-current={current === item.id ? "page" : undefined}>{item.label}</a>
          ))}
          <button class="search-btn" id="search-open" type="button" aria-label="Search" title="Search (Ctrl-K)">
            <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="9" r="6"></circle>
              <line x1="13.5" y1="13.5" x2="18" y2="18" stroke-linecap="round"></line>
            </svg>
            <span class="search-btn-txt">Search</span>
            <kbd>Ctrl K</kbd>
          </button>
          <button class="theme-btn" id="theme-toggle" type="button" aria-label="Toggle light/dark theme" title="Toggle theme">◐</button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <p>
          <strong>Moby-Dick: A Student Edition.</strong>
          Full text from <a href="https://standardebooks.org/ebooks/herman-melville/moby-dick" rel="noopener">Standard Ebooks</a> (public domain).
          Study notes are source-cited and student-reviewed.
        </p>
        <p class="muted">
          Built with Astro. <a href="https://github.com/JD-Jones-ASES/moby-dick-portal" rel="noopener">Source on GitHub</a>.
          A study tool, not a substitute for the book.
        </p>
      </div>
    </footer>

    <SearchOverlay />

    <script>
      import { initSearch } from "../lib/search-ui.js";
      initSearch();
    </script>

    <script is:inline>
      (function () {
        const btn = document.getElementById("theme-toggle");
        if (!btn) return;
        btn.addEventListener("click", function () {
          const root = document.documentElement;
          const next = root.dataset.theme === "night" ? "paper" : "night";
          root.dataset.theme = next;
          try { localStorage.setItem("mdp-theme", next); } catch (e) {}
        });
      })();
    </script>
  </body>
</html>
