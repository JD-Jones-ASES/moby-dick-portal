---
// A small nautical dingbat above a chapter opening — a compass star with a rule fading to the right,
// aligned to the title's left edge. Decorative (aria-hidden); fades in, honoring reduced motion (CSS).
---
<div class="chapter-flourish" aria-hidden="true">
  <svg class="cf-star" viewBox="0 0 24 24" width="17" height="17" fill="currentColor" role="presentation">
    <path d="M12 0.5 L13.7 10.3 L23.5 12 L13.7 13.7 L12 23.5 L10.3 13.7 L0.5 12 L10.3 10.3 Z"></path>
  </svg>
  <span class="cf-rule"></span>
</div>
